# =============================================================================
# Cold Scout OSS — Self-Hosted Configuration
# Copy this file to .env and fill in your own API keys.
# All costs are on YOUR accounts — Cold Scout bears no API cost.
# =============================================================================

# ── Google Places API ────────────────────────────────────────────────────────
# Create a GCP project → Enable Places API → Create Credentials → API Key
# $200/month free credit included with new GCP accounts
GOOGLE_PLACES_API_KEY=AIza_your_google_key

# ── AI / LLM (Groq — free tier available) ───────────────────────────────────
# Sign up at console.groq.com → API Keys → Create
GROQ_API_KEY=gsk_your_groq_key
GROQ_MODEL=llama-3.1-8b-instant

# ── Email Sending (Brevo SMTP — free 300 emails/day) ────────────────────────
# Sign up at brevo.com → SMTP & API → Generate SMTP Key
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your_brevo_user
BREVO_SMTP_PASSWORD=your_brevo_smtp_password
FROM_EMAIL=sender@yourdomain.com
FROM_NAME=Cold Scout
REPLY_TO_EMAIL=replies@yourdomain.com

# ── Admin ────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com

# ── Notifications (Optional) ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Pipeline Schedule (24h format, default IST) ─────────────────────────────
DISCOVERY_HOUR=6
QUALIFICATION_HOUR=7
PERSONALIZATION_HOUR=8
OUTREACH_HOUR=9
REPORT_HOUR=23
REPORT_MINUTE=30

# ── Branding ─────────────────────────────────────────────────────────────────
BOOKING_LINK=https://calendly.com/your-link
SENDER_ADDRESS=Your City, Your Country

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
